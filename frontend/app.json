{
  "expo": {
    "name": "You Are What You Eat",
    "slug": "you-are-what-you-eat",
    "version": "1.0.40",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.youarewhatyoueat.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan product barcodes to analyze ingredients",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "41"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.youarewhatyoueat.app",
      "versionCode": 41,
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "minSdkVersion": 24,
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Scan product barcodes to analyze ingredients"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#0c0c0c"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00e676"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-iap",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bcd7cf74-6fa3-4690-8ecf-1f01e912693d"
      }
    },
    "owner": "certifiedmalt",
    "description": "AI-powered food scanner that explains WHY ingredients are harmful. Unlike static scoring apps, our AI identifies ultra-processed ingredients and seed oils with scientific explanations and healthier alternatives."
  }
}